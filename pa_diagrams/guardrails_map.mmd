%% Enterprise AI — Guardrails & Security Control Map
%% What: All 9 active guardrails positioned at their enforcement points
%% Where: Inline within pipeline phases (not bolted on)
%% Why: Maps OWASP LLM Top 10 coverage — shows what's protected and where gaps remain

graph LR
    %% ══════════════════════════════════════
    %% PIPELINE PHASES (horizontal flow)
    %% ══════════════════════════════════════

    INPUT["User Upload<br/>(untrusted input)"]:::input

    subgraph P1["Phase 1 — Ingestion"]
        direction TB
        G1["G1-lite<br/>File Validator"]:::guard_active
        G1_DETAIL["• Magic bytes check<br/>• File size limit<br/>• SHA-256 fingerprint<br/>OWASP: LLM03 supply chain"]:::guard_detail

        G3["G3-lite<br/>Injection Scanner"]:::guard_active
        G3_DETAIL["• 10 regex patterns:<br/>  instruction override,<br/>  role switch, act_as,<br/>  system tags, ignore prev<br/>• Flags atom, doesn't block batch<br/>OWASP: LLM01 prompt injection"]:::guard_detail

        G2["G2<br/>PII Redactor"]:::guard_active
        G2_DETAIL["• Presidio NER engine<br/>• Regex fallback (email, phone, SSN)<br/>• Thread-safe singleton<br/>• Creates redaction_map<br/>  (placeholder → original)<br/>• PII restored only in Phase 5 CSV<br/>OWASP: LLM02 sensitive data"]:::guard_detail

        G1 --- G1_DETAIL
        G3 --- G3_DETAIL
        G2 --- G2_DETAIL
    end

    subgraph P2P3["Phases 2–3"]
        direction TB
        AUDIT_23["Audit Logging<br/>(all phases)"]:::guard_active
        AUDIT_DETAIL["• structlog JSON + correlation ID<br/>• Phase start/complete with hash<br/>• Never logs PII content<br/>• Prometheus metrics per call"]:::guard_detail
        AUDIT_23 --- AUDIT_DETAIL
    end

    subgraph P4["Phase 4 — Classification"]
        direction TB
        G8["G8<br/>Prompt Firewall"]:::guard_active
        G8_DETAIL["• Jinja2 autoescape=True<br/>• StrictUndefined (no missing vars)<br/>• Whitelist check in loader.py<br/>• User content in XML slots only<br/>• Template header: NEVER MODIFY<br/>  WITHOUT SECURITY REVIEW<br/>OWASP: LLM01, LLM06, LLM07"]:::guard_detail

        G9["G9<br/>Output Schema Enforcer"]:::guard_active
        G9_DETAIL["• Claude tool-use structured output<br/>• Pydantic validation on response<br/>• Constrained verdict enum:<br/>  FIT | PARTIAL_FIT | GAP<br/>• Retry on validation failure (max 3)<br/>• Fallback: REVIEW_REQUIRED<br/>OWASP: LLM06 excessive agency"]:::guard_detail

        G11["G11<br/>Response PII Scanner"]:::guard_active
        G11_DETAIL["• Scans LLM output fields:<br/>  rationale, config_steps,<br/>  gap_description<br/>• Reuses G2 presidio engine<br/>• If PII found: add G11 caveat<br/>  → Phase 5 routes to HITL<br/>OWASP: LLM02 data disclosure"]:::guard_detail

        G8 --- G8_DETAIL
        G9 --- G9_DETAIL
        G11 --- G11_DETAIL
    end

    subgraph P5["Phase 5 — Validation"]
        direction TB
        G10["G10-lite<br/>Sanity Gate"]:::guard_active
        G10_DETAIL["• high_confidence_gap<br/>  (confidence > 0.85 && GAP)<br/>• low_score_fit<br/>  (composite < 0.60 && FIT)<br/>• retry_exhausted<br/>  (REVIEW_REQUIRED)<br/>OWASP: LLM04 data poisoning"]:::guard_detail

        HITL["HITL<br/>Human Review"]:::guard_active
        HITL_DETAIL["• LangGraph interrupt()<br/>• Mandatory for all flags<br/>• Batch cannot complete<br/>  until all items resolved<br/>• Decisions feed Source C<br/>  (learning feedback loop)"]:::guard_detail

        G10 --- G10_DETAIL
        HITL --- HITL_DETAIL
    end

    OUTPUT["Validated Output<br/>(CSVs + PostgreSQL)"]:::output

    %% ── Flow ──
    INPUT --> P1 --> P2P3 --> P4 --> P5 --> OUTPUT

