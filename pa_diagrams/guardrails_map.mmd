        G5["G5 — KB integrity<br/>(hash verification on seed data)"]:::guard_deferred
        G6["G6 — Drift monitor<br/>(classification distribution shift)"]:::guard_deferred
        G7["G7 — Cost tracker<br/>(per-batch LLM cost ceiling)"]:::guard_deferred
        G12["G12 — Eval harness<br/>(golden-set regression)"]:::guard_deferred
        G13["G13 — Encryption at rest<br/>(PII field encryption)"]:::guard_deferred
    end

